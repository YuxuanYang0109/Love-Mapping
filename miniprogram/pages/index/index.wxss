.login-page {
  min-height: 100vh;
  padding: 48rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top left, rgba(252, 201, 89, 0.38), transparent 36%),
    radial-gradient(circle at bottom right, rgba(75, 180, 234, 0.28), transparent 34%),
    linear-gradient(160deg, #f7f1e7 0%, #f5f5f0 45%, #eef4f7 100%);
}

.login-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 44rpx 40rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 24rpx 60rpx rgba(28, 34, 42, 0.12);
  backdrop-filter: blur(14px);
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(17, 17, 17, 0.45);
}

.title {
  margin-top: 18rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #111111;
}

.subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(17, 17, 17, 0.64);
}

.login-input {
  width: 100%;
  height: 96rpx;
  margin-top: 34rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(17, 17, 17, 0.05);
  border: 2rpx solid rgba(17, 17, 17, 0.06);
  font-size: 30rpx;
  color: #111111;
}

.error-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b4232d;
}

.login-btn {
  height: 96rpx;
  margin-top: 30rpx;
  border-radius: 999rpx !important;
  background: #111111 !important;
  color: #ffffff !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
}
