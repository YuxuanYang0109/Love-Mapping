.page {
  position: relative;
  height: 100vh;
  width: 100vw;
}

.map {
  height: 100vh;
  width: 100vw;
}

/* 椤堕儴宸︿晶鍒嗘鎺т欢锛堥伩鍏嶅彸涓婄郴缁熻兌鍥婏級 */
.seg-wrap{
  position: absolute;
  left: 24rpx;
  height: 72rpx;
  width: 240rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 6rpx;
  z-index: 20;
  /* 绫?iOS 姣涚幓鐠冩劅锛堟湁鐨勬満鍨嬩細寮卞寲锛屼笉褰卞搷锛?*/
  backdrop-filter: blur(12px);
}

.seg-thumb{
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 114rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: rgba(17,17,17,0.92);
  box-shadow: 0 12rpx 26rpx rgba(0,0,0,0.18);
  transition: left 180ms ease;
}

.seg-thumb.right{
  left: 120rpx;
}

.seg-item{
  flex: 1;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(0,0,0,0.65);
  z-index: 1; /* 淇濊瘉鍦?thumb 涓婃柟鍙偣鍑?*/
}

.seg-item.active{
  color: #fff;
}

.corner-left-image{
  position: absolute;
  left: 0;
  bottom: 0;
  display: block;
  width: 440rpx;
  z-index: 24;
}

.fab-glass{
  position: absolute;
  right: 24rpx;
  bottom: 64rpx;
  z-index: 30;

  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;

  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(255,255,255,0.35);
  box-shadow: 0 16rpx 44rpx rgba(0,0,0,0.22);

  backdrop-filter: blur(14px);

  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-plus{
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.fab-plus-h,
.fab-plus-v{
  position: absolute;
  left: 50%;
  top: 50%;
  background: rgba(0,0,0,0.78);
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.fab-plus-h{
  width: 40rpx;
  height: 6rpx;
}

.fab-plus-v{
  width: 6rpx;
  height: 40rpx;
}

/* 閬僵灞?*/
.mask{
  position: absolute;
  inset: 0;
  z-index: 999;
  background: rgba(0,0,0,0.28);
}

/* 姝ｄ腑澶脊绐楀崱鐗?*/
.modal{
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);

  width: 640rpx;              /* 鎺ヨ繎婊″浣嗙暀杈?*/
  max-height: 70vh;
  padding: 22rpx;
  box-sizing: border-box;

  border-radius: 26rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(255,255,255,0.35);
  box-shadow: 0 26rpx 70rpx rgba(0,0,0,0.30);

  backdrop-filter: blur(16px);
  overflow: hidden;
}

/* 澶撮儴锛氫綔鑰?+ 鏃堕棿 */
.modal-header{
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.modal-title{
  font-size: 30rpx;
  color: rgba(17,17,17,0.88);
}

.modal-time{
  font-size: 22rpx;
  color: rgba(0,0,0,0.48);
}

/* 浣嶇疆 */
.modal-loc{
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(17,17,17,0.78);
  margin-bottom: 12rpx;
}

/* 鏂囨湰 */
.modal-text{
  font-size: 28rpx;
  color: rgba(17,17,17,0.86);
  line-height: 1.4;
}

/* 鍥剧墖 */
.modal-img{
  width: 100%;
  height: 360rpx;
  margin-top: 14rpx;
  border-radius: 20rpx;
}

/* 搴曢儴鎸夐挳鍖?*/
.modal-actions{
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.modal-btn{
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(0,0,0,0.06);
  color: rgba(17,17,17,0.72);
  font-size: 24rpx;
  font-weight: 800;
}
