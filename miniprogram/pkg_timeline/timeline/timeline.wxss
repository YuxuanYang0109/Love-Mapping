.page{
  min-height: 100vh;
  box-sizing: border-box;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 140rpx;
  background:#f6f6f6;
}

/* 给顶部 seg-toggle 留空间（避免挡住第一条） */
.list{
  padding-top: 90rpx;
  display:flex;
  flex-direction:column;
  gap: 16rpx;
}

.card{
  border-radius: 22rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 10rpx 24rpx rgba(0,0,0,0.06);
}

.card-top{
  display:flex;
  justify-content: space-between;
  align-items:center;
  margin-bottom: 10rpx;
}

.author{
  display:flex;
  align-items:center;
  gap: 10rpx;
}

.avatar{
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(17,17,17,0.86);
  border: 1rpx solid rgba(255,255,255,0.5);
}

.name{
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(17,17,17,0.86);
}

.time{
  font-size: 22rpx;
  color: rgba(0,0,0,0.45);
}

.loc{
  font-size: 30rpx;
  font-weight: 800;
  color:#111;
  margin-bottom: 12rpx;
}

.muted{
  color: rgba(0,0,0,0.45);
  font-weight: 600;
}

.photo{
  width: 100%;
}

.img{
  width: 100%;
  height: 320rpx;
  border-radius: 18rpx;
}

.footer{ 
  margin-top: 20rpx; 
  padding: 0 24rpx 12rpx; 
  width: 100vw; margin-left: -24rpx; 
 box-sizing: border-box;
 }

.btn{
  width: 100%;
  border-radius: 16rpx !important;
}

.avatar-img{
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,255,255,0.7);
}
